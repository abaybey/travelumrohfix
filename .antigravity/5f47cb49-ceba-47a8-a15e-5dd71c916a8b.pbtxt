  file_change {
    absolute_path_uri: "file:///src/components/PackageSection.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState, useMemo } from \"react\";\nimport { Search, Calendar, ChevronRight } from \"lucide-react\";\nimport { umrahPackages } from \"../data\";\nimport PackageCard from \"./PackageCard\";\n\nexport default function PackageSection() {\n  const [activeFilter, setActiveFilter] = useState<\"semua\" | \"hemat\" | \"premium\" | \"ramadan\">(\"semua\");\n  const [searchQuery, setSearchQuery] = useState(\"\");\n\n  const filters = [\n    { key: \"semua\", label: \"\342\234\250 Semua Paket\" },\n    { key: \"hemat\", label: \"\360\237\222\260 Hemat Ekonomis\" },\n    { key: \"premium\", label: \"\360\237\221\221 Bintang 5 VIP\" },\n    { key: \"ramadan\", label: \"\360\237\214\231 Spesial Ramadan\" }\n  ];\n\n  // Fitler logic using Memo for performance\n  const filteredPackages = useMemo(() => {\n    return umrahPackages.filter((pkg) => {\n      // 1. Text filter search\n      const matchesSearch =\n        pkg.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n        pkg.subtitle.toLowerCase().includes(searchQuery.toLowerCase()) ||\n        pkg.meccaHotel.toLowerCase().includes(searchQuery.toLowerCase()) ||\n        pkg.airline.toLowerCase().includes(searchQuery.toLowerCase());\n\n      if (!matchesSearch) return false;\n\n      // 2. Tab filter category\n      if (activeFilter === \"semua\") return true;\n      if (activeFilter === \"hemat\") return pkg.badge === \"Hemat\";\n      if (activeFilter === \"premium\") return pkg.badge === \"Excellent\" || pkg.badge === \"VIP Gold\";\n      if (activeFilter === \"ramadan\") return pkg.badge === \"Ramadan Special\";\n\n      return true;\n    });\n  }, [activeFilter, searchQuery]);\n\n  return (\n    <section id=\"packages-section\" className=\"py-24 bg-white relative\">\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6\">\n        {/* Section Header */}\n        <div className=\"text-center max-w-3xl mx-auto mb-12\">\n          <div className=\"inline-flex items-center gap-1.5 bg-amber-100 text-amber-800 text-xs font-extrabold px-3 py-1.5 rounded-full mb-3 uppercase tracking-wider\">\n            \360\237\225\213 Kuota Terbatas Keberangkatan 2026\n          </div>\n          <h2 className=\"text-3xl sm:text-4xl font-extrabold text-gray-900 tracking-tight font-sans leading-tight\">\n            Pilihan Paket Umrah Terbaik & <span className=\"text-emerald-800\">Sesuai Syariah</span>\n          </h2>\n          <p className=\"mt-4 text-base sm:text-lg text-gray-600\">\n            Pilih paket perjalanan umrah dengan akomodasi hotel dekat pelataran pelataran kiblat, maskapai reputasi tinggi, dan layanan katering menu Nusantara harian.\n          </p>\n        </div>\n\n        {/* Filters and Inputs Toolbar */}\n        <div className=\"flex flex-col md:flex-row gap-4 justify-between items-center bg-gray-50 p-4 rounded-2xl border border-gray-100 mb-10 shadow-sm\">\n          {/* Tabs Filter Selector */}\n          <div className=\"flex flex-wrap gap-1.5 p-1 bg-gray-200/60 rounded-xl w-full md:w-auto\">\n            {filters.map((filter) => (\n              <button\n                key={filter.key}\n                onClick={() => setActiveFilter(filter.key as any)}\n                className={`px-4 py-2 text-xs sm:text-sm font-bold rounded-lg transition-all flex-1 md:flex-none text-center cursor-pointer ${\n                  activeFilter === filter.key\n                    ? \"bg-white text-emerald-950 shadow-sm\"\n                    : \"text-gray-600 hover:text-emerald-900\"\n                }`}\n              >\n                {filter.label}\n              </button>\n            ))}\n          </div>\n\n          {/* Text Input Search Bar */}\n          <div className=\"relative w-full md:w-80\">\n            <Search className=\"w-4 h-4 text-gray-400 absolute left-3.5 top-1/2 transform -translate-y-1/2\" />\n            <input\n              type=\"text\"\n              placeholder=\"Cari hotel, bandara, maskapai...\"\n              value={searchQuery}\n              onChange={(e) => setSearchQuery(e.target.value)}\n              className=\"w-full bg-white text-gray-800 placeholder-gray-400 border border-gray-200 rounded-xl pl-10 pr-4 py-2.5 text-xs sm:text-sm focus:outline-none focus:ring-2 focus:ring-emerald-600 focus:border-transparent transition-all\"\n            />\n            {searchQuery && (\n              <button\n                onClick={() => setSearchQuery(\"\")}\n                className=\"absolute right-3.5 top-1/2 transform -translate-y-1/2 text-xs font-bold text-gray-400 hover:text-gray-600\"\n              >\n                Hapus\n              </button>\n            )}\n          </div>\n        </div>\n\n        {/* Packages Grid */}\n        {filteredPackages.length > 0 ? (\n          <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\">\n            {filteredPackages.map((pkg) => (\n              <PackageCard key={pkg.id} pkg={pkg} />\n            ))}\n          </div>\n        ) : (\n          <div className=\"py-16 text-center border border-dashed border-gray-200 rounded-3xl bg-gray-50\">\n            <p className=\"text-lg font-bold text-gray-900 mb-2\">Paket tidak ditemukan</p>\n            <p className=\"text-sm text-gray-500 max-w-sm mx-auto mb-6\">\n              Tidak ada paket umrah yang cocok dengan kriteria \"{searchQuery}\". Coba bersihkan pencarian atau ganti filter Anda.\n            </p>\n            <button\n              onClick={() => {\n                setSearchQuery(\"\");\n                setActiveFilter(\"semua\");\n              }}\n              className=\"inline-flex items-center gap-1.5 bg-emerald-800 text-white font-semibold text-xs px-4 py-2 rounded-lg hover:bg-emerald-900 transition-colors\"\n            >\n              Ulangi Pencarian\n            </button>\n          </div>\n        )}\n\n        {/* Small Notice */}\n        <div className=\"mt-12 bg-amber-50/70 border border-amber-200/60 rounded-2xl p-5 text-center max-w-3xl mx-auto\">\n          <p className=\"text-xs sm:text-sm text-gray-600\">\n            \360\237\222\241 <strong>Butuh penyesuaian khusus (Custom Group)?</strong> Kami melayani keberangkatan umrah swasta berkelompok (Keluarga, Korporasi, Organisasi) dengan harga negosiasi khusus, hotel custom, dan muthawwif privat.{\" \"}\n            <a\n              href=\"https://wa.me/6281234567890?text=Assalamualaikum%20Al-Haramain%20Umrah%2C%20saya%20tertarik%20untuk%20syuting%20tanya%20mengenai%20Layanan%20Private%20Group%20Umrah.\"\n              target=\"_blank\"\n              rel=\"noopener noreferrer\"\n              className=\"text-emerald-800 font-extrabold hover:underline\"\n            >\n              Konsultasikan Custom Group Anda \342\206\222\n            </a>\n          </p>\n        </div>\n      </div>\n    </section>\n  );\n}\n"
    }
