  file_change {
    absolute_path_uri: "file:///src/components/PackageCard.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState } from \"react\";\nimport { Clock, Calendar, Users2, Building2, ShieldCheck, Heart, PlaneTakeoff, HelpCircle } from \"lucide-react\";\nimport { UmrahPackage, CompanyInfo } from \"../types\";\nimport { companyData } from \"../data\";\n\ninterface PackageCardProps {\n  pkg: UmrahPackage;\n}\n\nexport default function PackageCard({ pkg }: PackageCardProps) {\n  // Sharing model state: \"quad\", \"triple\", or \"double\"\n  const [sharingType, setSharingType] = useState<\"quad\" | \"triple\" | \"double\">(\"quad\");\n\n  const getSharingPrice = () => {\n    switch (sharingType) {\n      case \"triple\":\n        return pkg.priceTriple;\n      case \"double\":\n        return pkg.priceDouble;\n      case \"quad\":\n      default:\n        return pkg.priceQuad;\n    }\n  };\n\n  const getSharingText = () => {\n    switch (sharingType) {\n      case \"triple\":\n        return \"Kamar Bertiga (Triple)\";\n      case \"double\":\n        return \"Kamar Berdua (Double)\";\n      case \"quad\":\n      default:\n        return \"Kamar Berempat (Quad)\";\n    }\n  };\n\n  // Format currency to IDR\n  const formatIDR = (num: number) => {\n    return new Intl.NumberFormat(\"id-ID\", {\n      style: \"currency\",\n      currency: \"IDR\",\n      minimumFractionDigits: 0,\n      maximumFractionDigits: 0\n    }).format(num);\n  };\n\n  const originalPriceQuad = pkg.priceQuad + 3500000; // Mock fake original price for countdown/discounts look\n  const getSharingOriginalPrice = () => {\n    switch (sharingType) {\n      case \"triple\":\n        return pkg.priceTriple + 4000000;\n      case \"double\":\n        return pkg.priceDouble + 4500000;\n      case \"quad\":\n      default:\n        return originalPriceQuad;\n    }\n  };\n\n  const handleBookingClick = () => {\n    const calculatedPrice = getSharingPrice();\n    const message = encodeURIComponent(\n      `Assalamualaikum Al-Haramain Umrah,\\n\\nSaya tertarik mendaftar untuk:\\n\360\237\223\246 *${pkg.name}*\\n\360\237\223\205 Jadwal Terbang: *${pkg.departureDate}*\\n\360\237\221\245 Kamar Pilihan: *${getSharingText()}*\\n\360\237\222\260 Harga Estimasi: *${formatIDR(calculatedPrice)} / pax*\\n\\nApakah masih ada slot yang tersedia? Mohon informasikan cara pembayarannya.`\n    );\n    window.open(`https://wa.me/${companyData.whatsappNumber}?text=${message}`, \"_blank\", \"noopener,noreferrer\");\n  };\n\n  // Quota percentage calculator\n  const percentFill = ((pkg.quotaTotal - pkg.seatsRemaining) / pkg.quotaTotal) * 100;\n\n  return (\n    <div\n      id={pkg.id}\n      className={`bg-white rounded-3xl overflow-hidden border transition-all duration-300 relative flex flex-col justify-between ${\n        pkg.isPopular\n          ? \"border-amber-400 shadow-2xl shadow-amber-900/10 ring-4 ring-amber-400/10 scale-[1.01]\"\n          : \"border-gray-200/85 hover:border-emerald-300 hover:shadow-xl hover:shadow-emerald-950/5\"\n      }`}\n    >\n      {/* Visual Badge Header */}\n      {pkg.isPopular && (\n        <div className=\"bg-amber-400 text-amber-950 text-xs font-black uppercase tracking-wider text-center py-1.5 font-sans\">\n          \360\237\224\245 Paket Terlaris - Rekomendasi Utama\n        </div>\n      )}\n\n      <div className=\"p-6\">\n        {/* Card Title & Badge */}\n        <div className=\"flex justify-between items-start gap-4 mb-4\">\n          <div>\n            <span\n              className={`inline-block text-[10px] uppercase font-black px-2.5 py-1 rounded-full mb-2 ${\n                pkg.badge === \"VIP Gold\"\n                  ? \"bg-amber-100 text-amber-900 border border-amber-300\"\n                  : pkg.badge === \"Excellent\"\n                  ? \"bg-emerald-100 text-emerald-900 border border-emerald-300\"\n                  : pkg.badge === \"Ramadan Special\"\n                  ? \"bg-purple-100 text-purple-900 border border-purple-300\"\n                  : \"bg-blue-100 text-blue-900 border border-blue-300\"\n              }`}\n            >\n              \342\200\242 {pkg.badge}\n            </span>\n            <h3 className=\"text-xl sm:text-2xl font-extrabold text-gray-900 leading-tight tracking-tight\">\n              {pkg.name}\n            </h3>\n            <p className=\"text-xs text-gray-500 mt-1 leading-relaxed\">\n              {pkg.subtitle}\n            </p>\n          </div>\n        </div>\n\n        {/* Dynamic Pricing Box */}\n        <div className=\"bg-emerald-50/80 rounded-2xl p-5 mb-6 border border-emerald-100 relative\">\n          <p className=\"text-[10px] text-emerald-800 uppercase font-bold tracking-wider\">Estimasi Harga Terbaik ({getSharingText()})</p>\n          <div className=\"flex items-baseline gap-2 mt-1\">\n            <span className=\"text-2xl sm:text-3xl font-black text-emerald-950\">\n              {formatIDR(getSharingPrice())}\n            </span>\n            <span className=\"text-xs text-gray-500 font-medium\">/ pax</span>\n          </div>\n          <div className=\"flex items-center gap-2 mt-1\">\n            <span className=\"text-xs text-red-500 line-through font-mono\">\n              {formatIDR(getSharingOriginalPrice())}\n            </span>\n            <span className=\"text-[9px] font-bold bg-red-100 text-red-600 px-1.5 py-0.5 rounded\">\n              Hemat {formatIDR(getSharingOriginalPrice() - getSharingPrice())}\n            </span>\n          </div>\n\n          {/* Interactive Share Type Selector Buttons */}\n          <div className=\"mt-4 pt-4 border-t border-emerald-100/60\">\n            <p className=\"text-[10px] text-gray-500 font-bold mb-2 uppercase tracking-wide\">Pilih Jenis Kamar Sekamar:</p>\n            <div className=\"grid grid-cols-3 gap-1.5 p-1 bg-gray-100 rounded-lg\">\n              <button\n                onClick={() => setSharingType(\"quad\")}\n                className={`py-1.5 text-[10px] sm:text-xs font-extrabold rounded-md transition-all ${\n                  sharingType === \"quad\"\n                    ? \"bg-white text-emerald-900 shadow-sm\"\n                    : \"text-gray-500 hover:text-gray-800\"\n                }`}\n              >\n                Quad (\360\237\221\244x4)\n              </button>\n              <button\n                onClick={() => setSharingType(\"triple\")}\n                className={`py-1.5 text-[10px] sm:text-xs font-extrabold rounded-md transition-all ${\n                  sharingType === \"triple\"\n                    ? \"bg-white text-emerald-900 shadow-sm\"\n                    : \"text-gray-500 hover:text-gray-800\"\n                }`}\n              >\n                Triple (\360\237\221\244x3)\n              </button>\n              <button\n                onClick={() => setSharingType(\"double\")}\n                className={`py-1.5 text-[10px] sm:text-xs font-extrabold rounded-md transition-all ${\n                  sharingType === \"double\"\n                    ? \"bg-white text-emerald-900 shadow-sm\"\n                    : \"text-gray-500 hover:text-gray-800\"\n                }`}\n              >\n                Double (\360\237\221\244x2)\n              </button>\n            </div>\n          </div>\n        </div>\n\n        {/* Quota Sisa Bar */}\n        <div className=\"mb-6\">\n          <div className=\"flex justify-between items-center text-xs text-gray-600 mb-1.5 font-medium\">\n            <span className=\"flex items-center gap-1\">\n              <span className=\"w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse inline-block\" />\n              Sisa Kuota Kursi\n            </span>\n            <span className=\"font-extrabold text-amber-600\">\n              {pkg.seatsRemaining} dari {pkg.quotaTotal} Seat Tersisa\n            </span>\n          </div>\n          <div className=\"w-full bg-gray-100 h-2 rounded-full overflow-hidden\">\n            <div\n              className={`h-full rounded-full transition-all duration-500 ${\n                pkg.seatsRemaining <= 5 ? \"bg-red-500\" : \"bg-emerald-600\"\n              }`}\n              style={{ width: `${percentFill}%` }}\n            />\n          </div>\n        </div>\n\n        {/* Flight & Hotel Keys */}\n        <div className=\"space-y-4 border-t border-gray-100 pt-5 mb-6\">\n          {/* Flight */}\n          <div className=\"flex items-start gap-3\">\n            <div className=\"text-xl bg-blue-50 text-blue-800 p-2 rounded-xl shrink-0\">\n              \342\234\210\357\270\217\n            </div>\n            <div>\n              <p className=\"text-[10px] text-gray-400 uppercase font-bold tracking-wider\">Penerbangan / Rute</p>\n              <p className=\"text-sm font-bold text-gray-800\">{pkg.airline}</p>\n              <p className=\"text-xs text-gray-500\">Jakarta Direct Saudi (PP)</p>\n            </div>\n          </div>\n\n          {/* Mecca Hotel */}\n          <div className=\"flex items-start gap-3\">\n            <div className=\"text-xl bg-amber-50 text-amber-800 p-2 rounded-xl shrink-0\">\n              \360\237\225\213\n            </div>\n            <div>\n              <p className=\"text-[10px] text-gray-400 uppercase font-bold tracking-wider\">Hotel Makkah</p>\n              <p className=\"text-sm font-bold text-gray-800 mb-0.5\">{pkg.meccaHotel}</p>\n              <div className=\"flex items-center gap-1.5\">\n                <span className=\"text-amber-400 tracking-tight text-xs flex\">\n                  {Array.from({ length: pkg.meccaHotelStars }).map((_, i) => (\n                    <span key={i}>\342\230\205</span>\n                  ))}\n                </span>\n                <span className=\"text-[11px] text-gray-500 font-medium\">({pkg.meccaHotelDistance})</span>\n              </div>\n            </div>\n          </div>\n\n          {/* Madinah Hotel */}\n          <div className=\"flex items-start gap-3\">\n            <div className=\"text-xl bg-emerald-50 text-emerald-800 p-2 rounded-xl shrink-0\">\n              \360\237\225\214\n            </div>\n            <div>\n              <p className=\"text-[10px] text-gray-400 uppercase font-bold tracking-wider\">Hotel Madinah</p>\n              <p className=\"text-sm font-bold text-gray-800 mb-0.5\">{pkg.madinahHotel}</p>\n              <div className=\"flex items-center gap-1.5\">\n                <span className=\"text-emerald-500 tracking-tight text-xs flex\">\n                  {Array.from({ length: pkg.madinahHotelStars }).map((_, i) => (\n                    <span key={i}>\342\230\205</span>\n                  ))}\n                </span>\n                <span className=\"text-[11px] text-gray-500 font-medium\">({pkg.madinahHotelDistance})</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        {/* Bullet Inclusions Highlights */}\n        <div className=\"bg-gray-50 py-4 px-5 rounded-2xl mb-6\">\n          <p className=\"text-[10px] text-gray-500 font-bold mb-2 uppercase tracking-wider\">Sudah Termasuk (Inclusions):</p>\n          <ul className=\"space-y-1.5\">\n            {pkg.highlights.map((high, index) => (\n              <li key={index} className=\"flex gap-2 items-start text-xs text-gray-700\">\n                <span className=\"text-emerald-600 mt-0.5 font-bold\">\342\234\223</span>\n                <span className=\"leading-tight\">{high}</span>\n              </li>\n            ))}\n          </ul>\n        </div>\n      </div>\n\n      {/* Booking CTA trigger buttons */}\n      <div className=\"p-6 bg-gray-50 border-t border-gray-100 rounded-b-3xl\">\n        <div className=\"grid grid-cols-1 gap-2.5\">\n          <button\n            onClick={handleBookingClick}\n            className=\"w-full inline-flex items-center justify-center gap-2 bg-emerald-600 hover:bg-emerald-700 active:bg-emerald-800 text-white font-extrabold py-3.5 px-4 rounded-xl shadow-lg shadow-emerald-700/10 hover:shadow-emerald-700/20 active:translate-y-px transition-all cursor-pointer text-sm\"\n          >\n            \360\237\222\254 Amankan Seat via WhatsApp\n          </button>\n        </div>\n        <div className=\"text-center mt-2.5\">\n          <span className=\"text-[10px] text-gray-400 font-medium tracking-wide flex items-center justify-center gap-1.5\">\n            <ShieldCheck className=\"w-3.5 h-3.5 text-emerald-600 inline\" />\n            DP Ringan Rp 5Jt & Garansi Legalitas\n          </span>\n        </div>\n      </div>\n    </div>\n  );\n}\n"
    }
    diff {
