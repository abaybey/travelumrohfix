  file_change {
    absolute_path_uri: "file:///src/components/CostEstimator.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState, useMemo } from \"react\";\nimport { Calculator, Plane, Sparkles, Send, ShieldCheck, Users2, Building2 } from \"lucide-react\";\nimport { companyData } from \"../data\";\n\nexport default function CostEstimator() {\n  // Simulator State variables\n  const [pilgrimsCount, setPilgrimsCount] = useState<number>(2);\n  const [roomClass, setRoomClass] = useState<\"quad\" | \"triple\" | \"double\" | \"single\">(\"double\");\n  const [hotelTier, setHotelTier] = useState<\"bintang3\" | \"bintang4\" | \"bintang5\">(\"bintang5\");\n  const [addOnHaramainTrain, setAddOnHaramainTrain] = useState<boolean>(true);\n  const [addOnVipGear, setAddOnVipGear] = useState<boolean>(false);\n  const [addOnPremiumCatering, setAddOnPremiumCatering] = useState<boolean>(true);\n\n  // Price matrix calculation\n  // Base cost per person based on hotels tier\n  const roomMultipliers = {\n    quad: 0,       // Baseline\n    triple: 2000000,\n    double: 4000000,\n    single: 9000000\n  };\n\n  const hotelBaseCosts = {\n    bintang3: 22000000, // cheap\n    bintang4: 28500000, // moderate\n    bintang5: 35000000  // luxury\n  };\n\n  const calculatedPerPerson = useMemo(() => {\n    let price = hotelBaseCosts[hotelTier];\n    price += roomMultipliers[roomClass];\n\n    // Add-on cost additions\n    if (addOnHaramainTrain) price += 1500000;\n    if (addOnVipGear) price += 1200000;\n    if (addOnPremiumCatering) price += 800000;\n\n    return price;\n  }, [roomClass, hotelTier, addOnHaramainTrain, addOnVipGear, addOnPremiumCatering]);\n\n  const calculatedTotal = useMemo(() => {\n    return calculatedPerPerson * pilgrimsCount;\n  }, [calculatedPerPerson, pilgrimsCount]);\n\n  // Format currency to IDR\n  const formatIDR = (num: number) => {\n    return new Intl.NumberFormat(\"id-ID\", {\n      style: \"currency\",\n      currency: \"IDR\",\n      minimumFractionDigits: 0,\n      maximumFractionDigits: 0\n    }).format(num);\n  };\n\n  const handleShareCalculation = () => {\n    const roomText = {\n      quad: \"Quad (Sekamar Berempat)\",\n      triple: \"Triple (Sekamar Bertiga)\",\n      double: \"Double (Sekamar Berdua)\",\n      single: \"Single (Kamar Sendiri)\"\n    }[roomClass];\n\n    const hotelText = {\n      bintang3: \"Hotel Bintang 3 Ekonomis (Jarak ~350m)\",\n      bintang4: \"Hotel Bintang 4 Nyaman (Jarak ~150m)\",\n      bintang5: \"Hotel Bintang 5 Premium (Dekat Pelataran/0m)\"\n    }[hotelTier];\n\n    const upgrades = [];\n    if (addOnHaramainTrain) upgrades.push(\"Kereta Cepat Haramain (Makkah-Madinah)\");\n    if (addOnVipGear) upgrades.push(\"Upgrade Perlengkapan VIP Koper Fiber\");\n    if (addOnPremiumCatering) upgrades.push(\"Full-Board Catering Premium\");\n\n    const message = encodeURIComponent(\n      `Assalamualaikum Al-Haramain Umrah,\\n\\nSaya telah membuat *Simulasi Rencana Umrah Swasta* melalui situs Anda. Berikut detail rencana saya:\\n\\n` +\n      `\360\237\221\245 Jumlah Jamaah: *${pilgrimsCount} Orang*\\n\\n` +\n      `\360\237\217\250 Klasifikasi Hotel: \\n\342\200\242 _${hotelText}_\\n\\n` +\n      `\360\237\233\214 Jenis Kamar: \\n\342\200\242 _${roomText}_\\n\\n` +\n      `\342\234\250 Layanan Tambahan (Upgrades):\\n${upgrades.map((u) => `\342\200\242 _${u}_`).join(\"\\n\") || \"\342\200\242 _Tidak ada_\"}\\n\\n` +\n      `\360\237\223\214 *ESTIMASI BIAYA:* \\n` +\n      `\342\200\242 Harga per pax: *${formatIDR(calculatedPerPerson)} / Orang*\\n` +\n      `\342\200\242 *TOTAL ESTIMASI (${pilgrimsCount} Pax): ${formatIDR(calculatedTotal)}*\\n\\n` +\n      `Mohon dibantu buatkan itinerary lengkap dan pengajuan tanggal keberangkatan yang sesuai. Terima kasih.`\n    );\n\n    window.open(`https://wa.me/${companyData.whatsappNumber}?text=${message}`, \"_blank\", \"noopener,noreferrer\");\n  };\n\n  return (\n    <section id=\"calc-section\" className=\"py-20 bg-emerald-950 text-white relative\">\n      {/* Visual background overlay patterns */}\n      <div className=\"absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(16,185,129,0.1),transparent_40%)]\" />\n      <div className=\"absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,rgba(245,158,11,0.05),transparent_40%)]\" />\n\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6 relative\">\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-center\">\n          {/* Left Area: Title Content */}\n          <div className=\"lg:col-span-5\">\n            <span className=\"inline-flex items-center gap-1.5 bg-emerald-800 text-amber-300 font-extrabold text-[10px] uppercase.tracking-wider px-3 py-1.5 rounded-full mb-4\">\n              <Calculator className=\"w-3.5 h-3.5\" /> Simulasi Biaya Mandiri\n            </span>\n            <h2 className=\"text-3xl sm:text-4xl font-extrabold text-white tracking-tight leading-tight\">\n              Rencanakan Umrah Impian Sesuai <span className=\"text-amber-400\">Budget Anda</span>\n            </h2>\n            <p className=\"mt-4 text-emerald-100 text-sm sm:text-base leading-relaxed\">\n              Bandingkan komponen akomodasi, jenis kamar sekamar, dan berbagai layanan khusus secara mandiri. Sistem kalkulator kami menghitung secara transparan untuk memberikan estimasi biaya realistis.\n            </p>\n\n            <div className=\"mt-8 space-y-4\">\n              <div className=\"flex gap-4 items-start bg-emerald-900/50 p-4 rounded-xl border border-emerald-900\">\n                <span className=\"text-emerald-400 font-bold text-xl mt-0.5\">\342\255\220</span>\n                <div>\n                  <h4 className=\"font-bold text-white text-sm\">Tanpa Biaya Tersembunyi</h4>\n                  <p className=\"text-xs text-emerald-300 mt-1 leading-relaxed\">Seluruh perhitungan di atas mencakup pajak visa negara Arab Saudi, katering reguler, asuransi, serta bus safar.</p>\n                </div>\n              </div>\n              <div className=\"flex gap-4 items-start bg-emerald-900/50 p-4 rounded-xl border border-emerald-900\">\n                <span className=\"text-amber-400 font-bold text-xl mt-0.5\">\360\237\224\224</span>\n                <div>\n                  <h4 className=\"font-bold text-white text-sm\">Diskon Keberangkatan Grup</h4>\n                  <p className=\"text-xs text-emerald-300 mt-1 leading-relaxed\">Untuk pendaftaran di atas 10 orang sekaligus, dapatkan potongan khusus Rp 1.000.000,-/pax langsung oleh tim admin di WhatsApp.</p>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          {/* Right Area: Interactive Calculator Card */}\n          <div className=\"lg:col-span-7 bg-white rounded-3xl text-gray-900 p-6 sm:p-8 shadow-2xl relative overflow-hidden\">\n            {/* Visual Header Card */}\n            <div className=\"mb-6 pb-4 border-b border-gray-100 flex justify-between items-center\">\n              <div>\n                <h3 className=\"text-lg font-bold text-gray-900 font-sans\">Kalkulator Rencana Umrah</h3>\n                <p className=\"text-xs text-gray-500\">Sesuaikan pilihan komponen umrah di bawah ini.</p>\n              </div>\n              <span className=\"text-2xl\">\360\237\223\213</span>\n            </div>\n\n            <div className=\"space-y-6\">\n              {/* Option 1: Pilgrim Count Slider */}\n              <div>\n                <div className=\"flex justify-between items-center mb-3\">\n                  <label className=\"text-xs sm:text-sm font-extrabold text-gray-700 flex items-center gap-1.5\">\n                    <Users2 className=\"w-4 h-4 text-emerald-700\" />\n                    Jumlah Jamaah (Anggota Rombongan):\n                  </label>\n                  <span className=\"bg-emerald-100 text-emerald-950 hover:bg-emerald-200 text-sm font-extrabold px-3 py-1 rounded-full font-mono transition-colors\">\n                    {pilgrimsCount} Orang\n                  </span>\n                </div>\n                <input\n                  type=\"range\"\n                  min=\"1\"\n                  max=\"10\"\n                  step=\"1\"\n                  value={pilgrimsCount}\n                  onChange={(e) => setPilgrimsCount(parseInt(e.target.value))}\n                  className=\"w-full accent-emerald-600 h-2 bg-gray-100 rounded-lg cursor-pointer transition-all\"\n                />\n                <div className=\"flex justify-between text-[10px] text-gray-400 font-bold px-1 mt-1.5 font-mono\">\n                  <span>1 Jamaah</span>\n                  <span>5 Orang</span>\n                  <span>10 Jamaah</span>\n                </div>\n              </div>\n\n              {/* Option 2: Hotels Tier Selector */}\n              <div>\n                <label className=\"text-xs sm:text-sm font-extrabold text-gray-700 flex items-center gap-1.5 mb-3\">\n                  <Building2 className=\"w-4 h-4 text-emerald-700\" />\n                  Kelas Hotel / Jarak ke Masjid:\n                </label>\n                <div className=\"grid grid-cols-3 gap-2.5\">\n                  <button\n                    onClick={() => setHotelTier(\"bintang3\")}\n                    className={`p-3 rounded-2xl border text-center transition-all cursor-pointer ${\n                      hotelTier === \"bintang3\"\n                        ? \"border-emerald-600 bg-emerald-50 text-emerald-950 font-bold ring-2 ring-emerald-600/10\"\n                        : \"border-gray-200 hover:border-gray-300 text-gray-600\"\n                    }`}\n                  >\n                    <span className=\"block text-sm sm:text-base font-extrabold\">\342\255\220\357\270\217\342\255\220\357\270\217\342\255\220\357\270\217</span>\n                    <span className=\"text-[10px] sm:text-xs block mt-1\">Bintang 3 Ekonomis</span>\n                    <span className=\"text-[9px] text-emerald-600 block mt-0.5\">\302\261350m ke Masjid</span>\n                  </button>\n\n                  <button\n                    onClick={() => setHotelTier(\"bintang4\")}\n                    className={`p-3 rounded-2xl border text-center transition-all cursor-pointer ${\n                      hotelTier === \"bintang4\"\n                        ? \"border-emerald-600 bg-emerald-50 text-emerald-950 font-bold ring-2 ring-emerald-600/10\"\n                        : \"border-gray-200 hover:border-gray-300 text-gray-600\"\n                    }`}\n                  >\n                    <span className=\"block text-sm sm:text-base font-extrabold\">\342\255\220\357\270\217\342\255\220\357\270\217\342\255\220\357\270\217\342\255\220\357\270\217</span>\n                    <span className=\"text-[10px] sm:text-xs block mt-1\">Bintang 4 Nyaman</span>\n                    <span className=\"text-[9px] text-emerald-600 block mt-0.5\">\302\261150m ke Masjid</span>\n                  </button>\n\n                  <button\n                    onClick={() => setHotelTier(\"bintang5\")}\n                    className={`p-3 rounded-2xl border text-center transition-all cursor-pointer ${\n                      hotelTier === \"bintang5\"\n                        ? \"border-emerald-600 bg-emerald-50 text-emerald-950 font-bold ring-2 ring-emerald-600/10\"\n                        : \"border-gray-200 hover:border-gray-300 text-gray-600\"\n                    }`}\n                  >\n                    <span className=\"block text-sm sm:text-base font-extrabold text-amber-500\">\342\255\220\357\270\217\342\255\220\357\270\217\342\255\220\357\270\217\342\255\220\357\270\217\342\255\220\357\270\217</span>\n                    <span className=\"text-[10px] sm:text-xs block mt-1\">Bintang 5 Luxury</span>\n                    <span className=\"text-[9px] text-emerald-600 block mt-0.5\">Pelataran Utama 0m</span>\n                  </button>\n                </div>\n              </div>\n\n              {/* Option 3: Room Occupancy Sharing Class */}\n              <div>\n                <label className=\"text-xs sm:text-sm font-extrabold text-gray-700 flex items-center gap-1.5 mb-2.5\">\n                  \360\237\233\214 Pilihan Tipe Kamar (Sharing):\n                </label>\n                <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-2\">\n                  {[\n                    { key: \"quad\", label: \"Quad (\360\237\221\244x4)\", cost: \"Baseline\" },\n                    { key: \"triple\", label: \"Triple (\360\237\221\244x3)\", cost: \"+Rp 2Jt\" },\n                    { key: \"double\", label: \"Double (\360\237\221\244x2)\", cost: \"+Rp 4Jt\" },\n                    { key: \"single\", label: \"Single (\360\237\221\244x1)\", cost: \"+Rp 9Jt\" }\n                  ].map((room) => (\n                    <button\n                      key={room.key}\n                      onClick={() => setRoomClass(room.key as any)}\n                      className={`py-2.5 px-2 rounded-xl border text-center transition-all cursor-pointer ${\n                        roomClass === room.key\n                          ? \"border-emerald-600 bg-emerald-50 text-emerald-950 font-bold\"\n                          : \"border-gray-200 hover:border-gray-300 text-gray-600\"\n                      }`}\n                    >\n                      <span className=\"block text-xs font-bold\">{room.label}</span>\n                      <span className=\"text-[9px] text-gray-400 block mt-0.5\">({room.cost})</span>\n                    </button>\n                  ))}\n                </div>\n              </div>\n\n              {/* Option 4: Upgrades & Add-ons Checklist */}\n              <div>\n                <label className=\"text-xs sm:text-sm font-extrabold text-gray-700 flex items-center gap-1.5 mb-2.5\">\n                  <Sparkles className=\"w-4 h-4 text-amber-500\" />\n                  Layanan Tambahan & Layanan Eksklusif:\n                </label>\n                <div className=\"space-y-2\">\n                  {/* Haramain Train */}\n                  <label className=\"flex items-center justify-between p-3.5 bg-gray-50 border border-gray-100 hover:border-emerald-100 rounded-2xl cursor-pointer transition-all select-none\">\n                    <div className=\"flex items-center gap-3\">\n                      <input\n                        type=\"checkbox\"\n                        checked={addOnHaramainTrain}\n                        onChange={(e) => setAddOnHaramainTrain(e.target.checked)}\n                        className=\"w-4.5 h-4.5 rounded text-emerald-600 pointer-events-none\"\n                      />\n                      <div>\n                        <span className=\"text-xs sm:text-sm font-extrabold text-gray-800 block\">Kereta Cepat Haramain (Bullet Train)</span>\n                        <span className=\"text-[10px] text-gray-500 block leading-tight\">Makkah-Madinah cuma 2 jam (menghindari letih bus 6 jam)</span>\n                      </div>\n                    </div>\n                    <span className=\"text-xs font-mono font-bold text-emerald-800 shrink-0 ml-3\">+Rp 1.500.000 /pax</span>\n                  </label>\n\n                  {/* VIP Gear */}\n                  <label className=\"flex items-center justify-between p-3.5 bg-gray-50 border border-gray-100 hover:border-emerald-100 rounded-2xl cursor-pointer transition-all select-none\">\n                    <div className=\"flex items-center gap-3\">\n                      <input\n                        type=\"checkbox\"\n                        checked={addOnVipGear}\n                        onChange={(e) => setAddOnVipGear(e.target.checked)}\n                        className=\"w-4.5 h-4.5 rounded text-emerald-600 pointer-events-none\"\n                      />\n                      <div>\n                        <span className=\"text-xs sm:text-sm font-extrabold text-gray-800 block\">Upgrade Perlengkapan VIP Koper Fiber</span>\n                        <span className=\"text-[10px] text-gray-500 block leading-tight\">Desain elegan anti pecah koper fiber & kain batik premium</span>\n                      </div>\n                    </div>\n                    <span className=\"text-xs font-mono font-bold text-emerald-800 shrink-0 ml-3\">+Rp 1.200.000 /pax</span>\n                  </label>\n\n                  {/* Premium Catering */}\n                  <label className=\"flex items-center justify-between p-3.5 bg-gray-50 border border-gray-100 hover:border-emerald-100 rounded-2xl cursor-pointer transition-all select-none\">\n                    <div className=\"flex items-center gap-3\">\n                      <input\n                        type=\"checkbox\"\n                        checked={addOnPremiumCatering}\n                        onChange={(e) => setAddOnPremiumCatering(e.target.checked)}\n                        className=\"w-4.5 h-4.5 rounded text-emerald-600 pointer-events-none\"\n                      />\n                      <div>\n                        <span className=\"text-xs sm:text-sm font-extrabold text-gray-800 block\">Full-board Catering Premium</span>\n                        <span className=\"text-[10px] text-gray-500 block leading-tight\">Makan prasmanan menu internasional di ruang makan VIP hotel</span>\n                      </div>\n                    </div>\n                    <span className=\"text-xs font-mono font-bold text-emerald-800 shrink-0 ml-3\">+Rp 800.000 /pax</span>\n                  </label>\n                </div>\n              </div>\n            </div>\n\n            {/* Simulated Calculations Block Output */}\n            <div className=\"mt-8 pt-6 border-t border-gray-100 bg-emerald-50 rounded-2xl p-5 border border-emerald-100/60 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4\">\n              <div>\n                <p className=\"text-[10px] text-emerald-800 uppercase font-black tracking-widest\">Total Estimasi Estimator ({pilgrimsCount} Pax)</p>\n                <p className=\"text-2xl sm:text-3xl font-black text-emerald-950 mt-1\">{formatIDR(calculatedTotal)}</p>\n                <p className=\"text-[10px] text-emerald-700/80 font-semibold mt-1\">({formatIDR(calculatedPerPerson)} / Orang)</p>\n              </div>\n\n              <button\n                onClick={handleShareCalculation}\n                className=\"inline-flex items-center justify-center gap-2 bg-emerald-600 hover:bg-emerald-700 active:bg-emerald-800 text-white font-extrabold py-3.5 px-5 rounded-xl shadow-lg cursor-pointer transform hover:-translate-y-px transition-all shrink-0 text-sm\"\n              >\n                <Send className=\"w-4.5 h-4.5 text-white/90\" />\n                <span>Ajukan di WhatsApp</span>\n              </button>\n            </div>\n\n            {/* Quick trust stamps */}\n            <p className=\"text-[10px] text-center text-gray-400 font-bold mt-4 tracking-wide uppercase flex items-center justify-center gap-1.5\">\n              <ShieldCheck className=\"w-4 h-4 text-emerald-600 inline\" />\n              Perhitungan Realistis Tanpa Tambahan Biaya Tersembunyi\n            </p>\n          </div>\n        </div>\n      </div>\n    </section>\n  );\n}\n"
    }
