    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { CheckCircle, ShieldCheck, Heart, FileText, ArrowRight } from \"lucide-react\";\nimport { stepsToRegister, requirementsDocuments } from \"../data\";\n\nexport default function Requirements() {\n  return (\n    <section id=\"req-section\" className=\"py-20 bg-gray-50 relative overflow-hidden\">\n      {/* Visual background accents */}\n      <div className=\"absolute top-1/2 left-0 w-[500px] h-[500px] bg-emerald-500/5 rounded-full blur-3xl -translate-y-1/2\" />\n\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6 relative\">\n        {/* Section Title */}\n        <div className=\"text-center max-w-3xl mx-auto mb-16\">\n          <div className=\"inline-flex items-center gap-1.5 bg-amber-100 text-amber-800 text-xs font-black px-3 py-1.5 rounded-full mb-3 uppercase tracking-wider\">\n            \360\237\223\235 Panduan Calon Jamaah\n          </div>\n          <h2 className=\"text-3xl sm:text-4xl font-extrabold text-gray-900 tracking-tight font-sans leading-tight\">\n            Syarat Mudah & <span className=\"text-emerald-800\">Alur Pendaftaran Umrah</span>\n          </h2>\n          <p className=\"mt-4 text-base sm:text-lg text-gray-600\">\n            Berikut tata cara melakukan registrasi aman serta rincian kelengkapan dokumen administratif wajib. Seluruh tim operasional kami siap memandu proses paspor & visa Anda.\n          </p>\n        </div>\n\n        {/* Part 1: Staggered Registration Steps (Vertical/Horizontal flow) */}\n        <div className=\"mb-20\">\n          <h3 className=\"text-xl sm:text-2xl font-extrabold text-gray-950 mb-8 text-center font-sans\">\n            5 Langkah Mudah Daftar Keberangkatan\n          </h3>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-5 gap-6 relative\">\n            {stepsToRegister.map((step, idx) => (\n              <div\n                key={idx}\n                className=\"bg-white rounded-2xl p-6 border border-gray-100 shadow-sm relative group hover:border-amber-300 transition-all\"\n              >\n                {/* Connecting arrow indicator for desktop */}\n                {idx < 4 && (\n                  <div className=\"hidden md:block absolute top-[44px] -right-5 transform translate-x-1/2 z-10 text-amber-400\">\n                    <ArrowRight className=\"w-5 h-5\" />\n                  </div>\n                )}\n\n                {/* Big steps serial number */}\n                <div className=\"text-4xl font-extrabold text-emerald-900/15 mb-4 group-hover:text-emerald-900/30 font-mono transition-colors\">\n                  {step.step}\n                </div>\n\n                <h4 className=\"font-extrabold text-gray-900 text-base leading-tight mb-2.5 font-sans\">\n                  {step.title}\n                </h4>\n\n                <p className=\"text-xs text-gray-500 leading-relaxed\">\n                  {step.desc}\n                </p>\n              </div>\n            ))}\n          </div>\n        </div>\n\n        {/* Part 2: Bento Requirements Grid */}\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch pt-6\">\n          {/* Left Block - List of exact documents requested */}\n          <div className=\"lg:col-span-7 bg-white rounded-3xl p-6 sm:p-8 border border-gray-100 shadow-xl shadow-gray-900/5\">\n            <h3 className=\"text-xl font-bold text-gray-900 mb-2 font-sans flex items-center gap-2\">\n              <FileText className=\"w-5 h-5 text-emerald-700\" /> Dokumen Wajib Pelengkap\n            </h3>\n            <p className=\"text-xs text-gray-500 mb-6 leading-relaxed\">\n              Kumpulkan seluruh berkas berikut minimal 30 hari sebelum tanggal keberangkatan umrah guna menjamin keamanan penerbitan visa elektronik di Siskopatuh.\n            </p>\n\n            <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n              {requirementsDocuments.map((doc, idx) => (\n                <div\n                  key={idx}\n                  className=\"p-4 bg-gray-50 border border-transparent rounded-2xl hover:bg-emerald-50/40 hover:border-emerald-100 transition-all\"\n                >\n                  <div className=\"flex gap-2.5 items-start\">\n                    <span className=\"text-emerald-700 shrink-0 mt-0.5\">\360\237\214\237</span>\n                    <div>\n                      <h4 className=\"font-bold text-gray-950 text-sm leading-tight mb-1\">\n                        {doc.title}\n                      </h4>\n                      <p className=\"text-xs text-gray-500 leading-relaxed\">\n                        {doc.detail}\n                      </p>\n                    </div>\n                  </div>\n                </div>\n              ))}\n            </div>\n          </div>\n\n          {/* Right Block - Vaccine, Insurance & Kit previews */}\n          <div className=\"lg:col-span-5 bg-gradient-to-br from-emerald-950 to-emerald-900 text-white rounded-3xl p-6 sm:p-8 shadow-xl relative overflow-hidden flex flex-col justify-between\">\n            <div className=\"absolute top-0 right-0 w-40 h-40 bg-amber-500/10 rounded-full blur-2xl\" />\n\n            <div>\n              <span className=\"inline-block bg-emerald-800 text-amber-300 font-extrabold text-[10px] tracking-wider px-2.5 py-1 rounded-full mb-4 uppercase\">\n                Penting Diketahui\n              </span>\n              <h3 className=\"text-xl sm:text-2xl font-extrabold text-white font-sans leading-tight mb-4\">\n                Sudah Termasuk Fasilitas Keberangkatan Lengkap\n              </h3>\n              <p className=\"text-xs sm:text-sm text-emerald-200 leading-relaxed mb-6\">\n                Kami melengkapi barang bawaan Anda dengan perlengkapan idaman terbaik untuk mengabdi penuh khusyuk di Al-Haramain:\n              </p>\n\n              {/* Checklists */}\n              <div className=\"space-y-3\">\n                <div className=\"flex gap-2.5 items-start\">\n                  <CheckCircle className=\"w-4.5 h-4.5 text-amber-400 shrink-0 mt-0.5\" />\n                  <span className=\"text-xs text-emerald-100\">Koper premium fiber beroda 24 inch (Ringan & Kuat)</span>\n                </div>\n                <div className=\"flex gap-2.5 items-start\">\n                  <CheckCircle className=\"w-4.5 h-4.5 text-amber-400 shrink-0 mt-0.5\" />\n                  <span className=\"text-xs text-emerald-100\">Batik seragam PT Al-Haramain Mulia Wisata</span>\n                </div>\n                <div className=\"flex gap-2.5 items-start\">\n                  <CheckCircle className=\"w-4.5 h-4.5 text-amber-400 shrink-0 mt-0.5\" />\n                  <span className=\"text-xs text-emerald-100\">Kain Ihram + Ikat Sabuk (Pria) / Mukena Premium (Wanita)</span>\n                </div>\n                <div className=\"flex gap-2.5 items-start\">\n                  <CheckCircle className=\"w-4.5 h-4.5 text-amber-400 shrink-0 mt-0.5\" />\n                  <span className=\"text-xs text-emerald-100\">Buku tuntunan doa berukuran saku & bag tag pengaman koper</span>\n                </div>\n              </div>\n            </div>\n\n            <div className=\"pt-6 border-t border-emerald-800/60 mt-6 flex items-center justify-between gap-4\">\n              <div className=\"text-xs text-emerald-300\">\n                <span className=\"font-semibold text-white block\">Suntik Vaksin Meningitis</span>\n                <span className=\"leading-normal opacity-85\">Rekomendasi dianjurkan di faskes KKP atau Kimia Farma</span>\n              </div>\n              <span className=\"text-3xl\">\360\237\222\211</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n  );\n}\n"
    }
