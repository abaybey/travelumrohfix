  file_change {
    absolute_path_uri: "file:///src/components/Testimonials.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { Star, MessageSquareCode, BadgeCheck } from \"lucide-react\";\nimport { testimonialData } from \"../data\";\n\nexport default function Testimonials() {\n  return (\n    <section id=\"testimoni-section\" className=\"py-24 bg-white relative overflow-hidden\">\n      {/* Visual background circles */}\n      <div className=\"absolute top-1/2 right-0 w-96 h-96 bg-amber-500/5 rounded-full blur-3xl\" />\n      <div className=\"absolute bottom-0 left-10 w-96 h-96 bg-emerald-500/5 rounded-full blur-3xl\" />\n\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6 relative\">\n        {/* Section Heading */}\n        <div className=\"text-center max-w-3xl mx-auto mb-16\">\n          <div className=\"inline-flex items-center gap-1.5 bg-amber-100 text-amber-800 text-xs font-bold px-3 py-1.5 rounded-full mb-3 uppercase tracking-wider\">\n            \342\255\220 Cerita Jamaah Al-Haramain\n          </div>\n          <h2 className=\"text-3xl sm:text-4xl font-extrabold text-gray-900 tracking-tight font-sans leading-tight\">\n            Kisah Khidmat & <span className=\"text-emerald-800\">Review Jujur Jamaah</span>\n          </h2>\n          <p className=\"mt-4 text-base sm:text-lg text-gray-650\">\n            Berikut kesaksian murni tanpa rekayasa dari para bapak, ibu, serta keluarga yang memercayakan safar suci ibadah umrah mereka kepada PT Al-Haramain Mulia Wisata.\n          </p>\n        </div>\n\n        {/* Testimonials Review Cards Grid */}\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\n          {testimonialData.map((test) => (\n            <div\n              key={test.id}\n              className=\"bg-gray-50/50 p-6 sm:p-8 rounded-3xl border border-gray-150 shadow-sm hover:border-amber-300 hover:bg-white hover:shadow-xl hover:shadow-emerald-950/5 transition-all duration-300 relative flex flex-col justify-between\"\n            >\n              <div>\n                {/* Upper row: Star rating and Quote icon */}\n                <div className=\"flex justify-between items-center mb-5\">\n                  <div className=\"flex text-amber-400 gap-0.5 text-sm\">\n                    {Array.from({ length: test.rating }).map((_, i) => (\n                      <Star key={i} className=\"w-4 h-4 fill-amber-400 text-amber-400\" />\n                    ))}\n                  </div>\n                  <MessageSquareCode className=\"w-8 h-8 text-emerald-950/10\" />\n                </div>\n\n                {/* Review Text */}\n                <p className=\"text-gray-700 text-sm sm:text-base leading-relaxed italic mb-6 font-sans\">\n                  \" {test.text} \"\n                </p>\n              </div>\n\n              {/* Pilgrim Meta Profile Card Info */}\n              <div className=\"flex items-center justify-between gap-4 pt-5 border-t border-gray-100 mt-auto\">\n                <div className=\"flex items-center gap-3\">\n                  <div className=\"w-11 h-11 rounded-full bg-emerald-100 flex items-center justify-center text-xl border border-emerald-200\">\n                    {test.name.includes(\"Hj.\") ? \"\360\237\247\225\" : \"\360\237\227\243\357\270\217\"}\n                  </div>\n                  <div>\n                    <h4 className=\"font-extrabold text-gray-950 text-sm leading-tight flex items-center gap-1\">\n                      {test.name}\n                      <BadgeCheck className=\"w-4 h-4 text-emerald-600 inline shrink-0\" />\n                    </h4>\n                    <p className=\"text-[11px] text-gray-500 font-medium\">\n                      Usia {test.age} tahun \342\200\242 Dari {test.city}\n                    </p>\n                  </div>\n                </div>\n\n                <div className=\"text-right shrink-0\">\n                  <span className=\"inline-block bg-emerald-50 text-emerald-800 text-[10px] font-black px-2.5 py-1 rounded-full border border-emerald-100 uppercase\">\n                    {test.packageTaken}\n                  </span>\n                  <p className=\"text-[10px] text-gray-400 font-mono mt-1 font-bold\">\n                    Safar: {test.date}\n                  </p>\n                </div>\n              </div>\n            </div>\n          ))}\n        </div>\n\n        {/* Dynamic Image banner between Sections */}\n        <div className=\"mt-16 bg-emerald-950 rounded-3xl p-8 sm:p-12 relative overflow-hidden text-white shadow-2xl relative\">\n          {/* Background image visual of Madinah Green Dome */}\n          <div className=\"absolute inset-0 z-0\">\n            <img\n              src=\"/src/assets/images/madinah_banner_1779350908562.png\"\n              alt=\"Masjid an-Nabawi Madinah\"\n              className=\"w-full h-full object-cover object-center opacity-25\"\n              referrerPolicy=\"no-referrer\"\n            />\n            <div className=\"absolute inset-0 bg-gradient-to-r from-emerald-950/95 to-emerald-950/80\" />\n          </div>\n\n          <div className=\"relative z-10 max-w-2xl text-left space-y-4\">\n            <span className=\"inline-block bg-amber-400/20 text-amber-300 font-black text-[10px] tracking-widest uppercase px-3 py-1 rounded-full border border-amber-400/20\">\n              Menyelesaikan Ziarah Madinah Al-Munawwarah\n            </span>\n            <h3 className=\"text-2xl sm:text-3xl font-extrabold text-white leading-tight font-sans\">\n              Mengharap Ridho Allah, Meraih Syafaat Rasulullah SAW\n            </h3>\n            <p className=\"text-xs sm:text-sm text-emerald-100/90 leading-relaxed max-w-xl\">\n              \"Barangsiapa melakukan ibadah haji atau umrah lalu meninggal dunia, maka dia mati seperti mati syahid dan dia akan masuk surga tanpa hisab.\" \342\200\224 Hadis Riwayat Tabrani.\n            </p>\n            <div className=\"pt-2\">\n              <span className=\"text-amber-400 font-mono text-xs font-bold block\">\342\230\205 Biro Aman Resmi \342\200\242 Pelayanan Sepenuh Hati \342\200\242 Muthawwif Bersertifikat \342\230\205</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n  );\n}\n"
    }
