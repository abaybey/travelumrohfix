    replacement_chunks {
      replacement_content: "import { UmrahPackage, CompanyInfo, FAQItem, Testimonial } from \"./types\";\n\nexport const companyData: CompanyInfo = {\n  brandName: \"Al-Haramain Umrah\",\n  legalName: \"PT Al-Haramain Mulia Wisata\",\n  ppiuNumber: \"Kemenag RI PPIU No. 129 Tahun 2024\",\n  address: \"Graha Al-Haramain, Lantai 2, Jl. Jend. Sudirman No. 45, Karet Semanggi, Jakarta Selatan, DKI Jakarta 12930\",\n  officeHours: \"Senin - Jumat: 08.00 - 17.00 WIB | Sabtu: 09.00 - 13.00 WIB\",\n  phone: \"021-555-8899\",\n  whatsappNumber: \"6281234567890\", // Standard prefilled format\n  whatsappDisplay: \"+62 812-3456-7890\",\n  email: \"info@alharamainumroh.co.id\",\n  socials: {\n    instagram: \"@alharamain.umrohtravel\",\n    facebook: \"Al-Haramain Umrah & Haji\",\n    youtube: \"Al-Haramain Wisata TV\",\n  }\n};\n\nexport const umrahPackages: UmrahPackage[] = [\n  {\n    id: \"pkg-hemat\",\n    name: \"Paket Umrah Syawal Barokah\",\n    subtitle: \"Solusi ibadah khusyuk dengan harga terjangkau & akomodasi nyaman berjarak dekat.\",\n    badge: \"Hemat\",\n    durationDays: 9,\n    priceQuad: 27500000,\n    priceTriple: 29500000,\n    priceDouble: 31500000,\n    departureMonth: \"Syawal / Mei 2026\",\n    departureDate: \"15 Mei 2026\",\n    airline: \"Lion Air Premium (Direct Jeddah)\",\n    airlineLogo: \"\360\237\246\201\",\n    meccaHotel: \"Anjum Hotel Makkah\",\n    meccaHotelStars: 5,\n    meccaHotelDistance: \"50 meter (Halaman Depan)\",\n    madinahHotel: \"Rove Al Madinah Hotel\",\n    madinahHotelStars: 4,\n    madinahHotelDistance: \"100 meter ke pelataran\",\n    highlights: [\n      \"Penerbangan langsung tanpa transit Jakarta-Jeddah\",\n      \"Bimbingan Manasik Umrah intensif 2 kali di tanah air\",\n      \"Muthawwif berpengalaman lulusan Universitas Islam Madinah\",\n      \"Air Zam-Zam 5 liter (sesuai regulasi Saudi)\"\n    ],\n    inclusions: [\n      \"Tiket pesawat PP kelas ekonomi\",\n      \"Visa Umrah & asuransi perjalanan\",\n      \"Hotel di Makkah & Madinah sesuai paket\",\n      \"Makan 3 kali sehari menu nusantara (Catering)\",\n      \"Transportasi Bus Executive AC terbaru\",\n      \"Ziarah kota Makkah dan Madinah\"\n    ],\n    exclusions: [\n      \"Pembuatan Paspor\",\n      \"Suntik Vaksin Meningitis (bila diwajibkan)\",\n      \"Pengeluaran pribadi (laundry, telepon, sim card saudi)\",\n      \"Kelebihan bagasi maskapai\"\n    ],\n    quotaTotal: 45,\n    seatsRemaining: 12\n  },\n  {\n    id: \"pkg-excellent\",\n    name: \"Paket Umrah Gold Excellent\",\n    subtitle: \"Paket terlaris dengan akomodasi hotel bintang 5 langsung menghadap Masjidil Haram.\",\n    badge: \"Excellent\",\n    durationDays: 12,\n    priceQuad: 36900000,\n    priceTriple: 38900000,\n    priceDouble: 41500000,\n    departureMonth: \"Juni 2026\",\n    departureDate: \"08 Juni 2026\",\n    airline: \"Saudia Airlines (Direct Madinah)\",\n    airlineLogo: \"\342\234\210\357\270\217\",\n    meccaHotel: \"Swiss\303\264tel Al Maqam Makkah\",\n    meccaHotelStars: 5,\n    meccaHotelDistance: \"0 meter (Koneksi langsung Zamzam Tower)\",\n    madinahHotel: \"Pullman Zamzam Madinah\",\n    madinahHotelStars: 5,\n    madinahHotelDistance: \"50 meter ke pintu Bab Fahd\",\n    highlights: [\n      \"Terbang langsung Jakarta-Madinah via Saudia Airlines\",\n      \"Akomodasi hotel bintang 5 di lingkaran pelataran utama Masjid\",\n      \"Ziarah Masjid Quba, kebun kurma, dan jabal Uhud eksklusif\",\n      \"Free satu set perlengkapan ibadah premium (Koper, kain ihram/mukena, batik)\"\n    ],\n    inclusions: [\n      \"Tiket Saudia Airlines PP\",\n      \"Visa Umrah & Asuransi Kesehatan Saudi\",\n      \"Hotel Bintang 5 di Makkah & Madinah\",\n      \"Makan 3 kali sehari prasmanan menu masakan Indonesia & Internasional\",\n      \"Air Zam-Zam 5L & Mutawwif bersertifikat\",\n      \"Perlengkapan umrah lengkap & manasik di hotel berbintang\"\n    ],\n    exclusions: [\n      \"Biaya kurir pengiriman perlengkapan\",\n      \"Kebutuhan laundry & tips muthawwif (sukarela)\",\n      \"Pengurusan dokumen paspor baru\"\n    ],\n    isPopular: true,\n    quotaTotal: 40,\n    seatsRemaining: 6\n  },\n  {\n    id: \"pkg-vip\",\n    name: \"Paket Al-Haramain VIP Sultan\",\n    subtitle: \"Ibadah premium dengan kenyamanan mutlak, penerbangan Business Class, dan hotel bintang 5 VIP.\",\n    badge: \"VIP Gold\",\n    durationDays: 12,\n    priceQuad: 49500000,\n    priceTriple: 52900000,\n    priceDouble: 56500000,\n    departureMonth: \"Agustus 2026\",\n    departureDate: \"20 Agustus 2026\",\n    airline: \"Garuda Indonesia (Direct Madinah)\",\n    airlineLogo: \"\360\237\246\205\",\n    meccaHotel: \"Fairmont Makkah Clock Royal Tower\",\n    meccaHotelStars: 5,\n    meccaHotelDistance: \"0 meter (Di dalam kompleks Abraj Al-Bait)\",\n    madinahHotel: \"The Oberoi Madinah\",\n    madinahHotelStars: 5,\n    madinahHotelDistance: \"Langkah kaki sangat dekat ke pintu utama\",\n    highlights: [\n      \"Penerbangan Langsung Garuda Indonesia, kenyamanan maskapai nasional terbaik\",\n      \"Kamar Kaaba View / Haram View (opsional request)\",\n      \"Muthawwif khushus bertitel S2/S3 Syariah untuk pendampingan fiqih detail\",\n      \"Kereta Cepat Haramain (Makkah - Madinah Express Bullet Train) kelas Business\"\n    ],\n    inclusions: [\n      \"Tiket Garuda Indonesia PP (Kelas Bisnis / Ekonomi Executive)\",\n      \"Visa Umrah & Tasreeh Raudhah otomatis\",\n      \"Hotel Bintang 5 Signature Makkah & Madinah\",\n      \"Makan prasmanan bintang 5 (Dine-in full board hotel)\",\n      \"Tiket Bullet Train Haramain kelas Bisnis\",\n      \"Private VIP Bus untuk seluruh penjemputan\",\n      \"Perlengkapan Umrah VIP Koper Fiber Premium & Batik Sutra\"\n    ],\n    exclusions: [\n      \"Belanja pribadi di pusat perbelanjaan Makkah/Madinah\",\n      \"Upgrade pelayanan kamar ke Single Room (sesuai request)\"\n    ],\n    quotaTotal: 25,\n    seatsRemaining: 4\n  },\n  {\n    id: \"pkg-ramadan\",\n    name: \"Paket Lailatul Qadar Akhir Ramadan\",\n    subtitle: \"Rasakan nikmatnya berpuasa penuh dan meraih kemuliaan malam Lailatul Qadar di Makkah.\",\n    badge: \"Ramadan Special\",\n    durationDays: 15,\n    priceQuad: 59000000,\n    priceTriple: 64000000,\n    priceDouble: 69900000,\n    departureMonth: \"Ramadan 1447 H / Maret 2026\",\n    departureDate: \"10 Maret 2026\",\n    airline: \"Qatar Airways (Transit Doha)\",\n    airlineLogo: \"\360\237\207\266\360\237\207\246\",\n    meccaHotel: \"Hilton Suites Makkah\",\n    meccaHotelStars: 5,\n    meccaHotelDistance: \"70 meter ke Masjidil Haram\",\n    madinahHotel: \"Haramara Al Aqeeq Hotel\",\n    madinahHotelStars: 5,\n    madinahHotelDistance: \"100 meter ke pelataran\",\n    highlights: [\n      \"Mengalami 10 malam terakhir Ramadan di Makkah\",\n      \"Solat Tarawih & Tahajud berjamaah langsung di Masjidil Haram\",\n      \"Paket Buka Puasa (Iftar) & Sahur prasmanan khas nusantara disediakan lengkap\",\n      \"Atmosfer spiritual luar biasa setara ibadah Haji\"\n    ],\n    inclusions: [\n      \"Tiket Qatar Airways PP\",\n      \"Visa Umrah spesifik Ramadan Saudi\",\n      \"Fasilitas hotel premium dekat pelataran agar mudah solat malam\",\n      \"Menu buka puasa & sahur harian lengkap\",\n      \"Mutawwif pendamping solat i\'tikaf malam\",\n      \"Perlengkapan umrah & air Zamzam premium\"\n    ],\n    exclusions: [\n      \"Overweight bagasi di atas 30kg\",\n      \"Pengeluaran oleh-oleh keluarga\"\n    ],\n    quotaTotal: 30,\n    seatsRemaining: 3\n  }\n];\n\nexport const faqData: FAQItem[] = [\n  {\n    id: \"faq-1\",\n    question: \"Apakah PT Al-Haramain Mulia Wisata sudah memiliki izin resmi PPIU?\",\n    answer: \"Ya, Al-Haramain Umrah beroperasi di bawah PT Al-Haramain Mulia Wisata dengan izin resmi dari Kementerian Agama Republik Indonesia (Kemenag) Penyelenggara Perjalanan Ibadah Umrah (PPIU) No. 129 Tahun 2024. Anda dapat memverifikasi legalitas kami langsung melalui aplikasi umrah resmi Kemenag (Pusaka atau Siskopatuh).\",\n    category: \"umum\"\n  },\n  {\n    id: \"faq-2\",\n    question: \"Apa saja dokumen yang harus disiapkan untuk mendaftar?\",\n    answer: \"Dokumen yang wajib disiapkan adalah: (1) Paspor asli dengan masa berlaku minimal 8 bulan sebelum keberangkatan dan nama minimal berisi 2 kata, (2) Kartu Keluarga (KK) asli & KTP untuk validasi pendaftaran, (3) Buku Nikah asli bagi pasangan suami istri, (4) Pasfoto terbaru latar belakang putih fokus wajah 80% ukuran 4x6 sebanyak 4 lembar, (5) Kartu Vaksin covid (jika diminta regulasi terbaru).\",\n    category: \"dokumen\"\n  },\n  {\n    id: \"faq-3\",\n    question: \"Bagaimana sistem pembayaran dan pelunasannya?\",\n    answer: \"Sistem pembayaran kami sangat transparan: (1) Membayar Uang Muka (DP) sebesar Rp 5.000.000 per orang untuk mengamankan seat penerbangan & hotel, (2) Pembayaran tahap dua dicicil sesuai kesepakatan, (3) Pelunasan wajib diselesaikan maksimal 45 hari sebelum tanggal jadwal keberangkatan untuk keperluan penerbitan visa dan tiket.\",\n    category: \"pembayaran\"\n  },\n  {\n    id: \"faq-4\",\n    question: \"Di mana lokasi pembekalan (Manasik) Umrah dilakukan dan berapa kali?\",\n    answer: \"Manasik Umrah dilaksanakan sebanyak 2 kali. Manasik pertama bertempat di ruang pertemuan kantor pusat kami atau hotel berbintang setaraf, membahas rukun ibadah fiqih dan tata cara ibadah praktis. Manasik kedua dilaksanakan 1 hari sebelum keberangkatan di hotel bandara transit, mencakup pembagian paspor, koper kabin, serta pemantapan praktis berpakaian ihram.\",\n    category: \"umum\"\n  },\n  {\n    id: \"faq-5\",\n    question: \"Apakah harga paket sudah termasuk seluruh perlengkapan umrah?\",\n    answer: \"Betul sekali. Harga paket yang kami cantumkan bersifat ALL-IN, di mana Anda telah mendapatkan koper fiber beroda 24 inch, tas selempang paspor, kain ihram & sabuk (untuk jamaah pria), mukena & bergo (untuk jamaah wanita), kain batik seragam esklusif, buku panduan doa saku, audio receiver guide salat, dan kantong sandal sandang.\",\n    category: \"fasilitas\"\n  },\n  {\n    id: \"faq-6\",\n    question: \"Bagaimana jika jamaah membatalkan keberangkatan karena sakit atau urusan mendesak?\",\n    answer: \"Kebijakan pembatalan mengacu pada aturan maskapai dan hotel Saudi: (1) Pembatalan setelah bayar DP dikenakan penalti biaya booking maskapai, (2) Pembatalan <30 hari dikenakan potongan 50% dari harga paket, (3) Pembatalan <14 hari dikenakan potongan hingga 85% karena seluruh tiket pesawat dan visa serta hotel berbayar mutlak non-refundable oleh provider Arab Saudi.\",\n    category: \"pembayaran\"\n  }\n];\n\nexport const testimonialData: Testimonial[] = [\n  {\n    id: \"test-1\",\n    name: \"H. Bambang Sulistyo\",\n    age: 54,\n    city: \"Surabaya\",\n    text: \"Alhamdulillah sangat mabrur! Pelayanan dari PT Al-Haramain luar biasa ramah. Jarak hotel Swiss\303\264tel Al Maqam di Makkah ke masjid sangat dekat, tinggal turun lift sudah sampai pelataran tawaf. Mutawwif ustadz lulusan Madinah membimbing kami dengan sabar dari fardhu hingga sunnah.\",\n    packageTaken: \"Paket Excellent Bintang 5\",\n    rating: 5,\n    date: \"Maret 2026\"\n  },\n  {\n    id: \"test-2\",\n    name: \"Hj. Ratna Safitri & Keluarga\",\n    age: 41,\n    city: \"Bandung\",\n    text: \"Mendaftar paket Ramadan kemarin bersama suami dan 3 anak. Walau musim padat (peak season) tarawih ramai, koordinasi dari tim Al-Haramain sangat sigap. Makanan catering nusantara di hotel selalu fresh, cocok dengan lidah anak-anak. Terima kasih tak terhingga, recommended sekali!\",\n    packageTaken: \"Paket Ramadan Lailatul Qadar\",\n    rating: 5,\n    date: \"April 2026\"\n  },\n  {\n    id: \"test-3\",\n    name: \"Ustadz Ahmad Fauzan\",\n    age: 35,\n    city: \"Medan\",\n    text: \"Sebagai pembimbing jamaah mandiri, saya sangat terbantu dengan kesiapan operasional AlHaramain. Penyaluran visa kilat, pendaftaran jadwal Raudhah (Tasreeh) lancar tanpa kendala, dan bus ziarah yang bersih serta dingin ber-AC mumpuni. Nilai kesempurnaan bintang lima.\",\n    packageTaken: \"Paket VIP Sultan\",\n    rating: 5,\n    date: \"Januari 2026\"\n  },\n  {\n    id: \"test-4\",\n    name: \"Siti Rahmawati\",\n    age: 29,\n    city: \"Tangerang\",\n    text: \"Pertama kali umroh sendirian sempat merasa cemas. Untungnya group pendampingan whatsapp aktif sejak sebelum berangkat. Teman kamar sekamar dari jamaah hemat sangat akrab. Pelayanan muthawwif wanita (Muthawwifah) membimbing kami berziarah pilar-pilar wanita di Raudhah dengan aman.\",\n    packageTaken: \"Paket Umrah Syawal\",\n    rating: 5,\n    date: \"Mei 2026\"\n  }\n];\n\nexport const stepsToRegister = [\n  {\n    step: \"01\",\n    title: \"Pilih Paket & Konsultasi\",\n    desc: \"Tentukan paket impian yang sesuai jadwal & anggaran Anda. Hubungi kami via WA/Telepon untuk konsultasi kuota tersedia.\"\n  },\n  {\n    step: \"02\",\n    title: \"Membayar DP & Amankan Seat\",\n    desc: \"Bayar uang muka (DP) sebesar Rp 5.000.000,- untuk booking tiket pesawat & asuransi. Kirimkan foto lembar pertama paspor Anda.\"\n  },\n  {\n    step: \"03\",\n    title: \"Lengkapi Dokumen & Firasat\",\n    desc: \"Kumpulkan paspor fisik, pasfoto, buku nikah/kartu keluarga ke kantor kami. Tim kami akan memproses Visa & Tasreeh Raudhah Anda.\"\n  },\n  {\n    step: \"04\",\n    title: \"Manasik & Pelunasan\",\n    desc: \"Ikuti pembekalan manasik intensif baik teori & praktek ibadah. Lakukan pelunasan sisa biaya paket maksimal 45 hari sebelum terbang.\"\n  },\n  {\n    step: \"05\",\n    title: \"Safar Keberangkatan\",\n    desc: \"Berkumpul di Bandara Soekarno-Hatta sesuai instruksi. Nikmati safar ibadah yang khusyuk, aman, & dipandu muthawwif bersertifikat.\"\n  }\n];\n\nexport const requirementsDocuments = [\n  {\n    title: \"Paspor Asli\",\n    detail: \"Masa berlaku paspor minimal 8 bulan sebelum jadwal terbang. Nama di paspor minimal terdiri dari 2 kata (contoh: Ahmad Zaki).\"\n  },\n  {\n    title: \"KTP & Kartu Keluarga (KK)\",\n    detail: \"Salinan KTP berwarna dan KK asli untuk keperluan pengurusan visa umrah & asuransi kesehatan kerajaan Saudi.\"\n  },\n  {\n    title: \"Pasfoto Terbaru\",\n    detail: \"Ukuran foto 4x6 sebanyak 4 lembar dengan latar belakang putih, rasio fokus wajah 80%, tidak mengenakan kacamata hitam/seragam dinas.\"\n  },\n  {\n    title: \"Buku Nikah & Akta Lahir\",\n    detail: \"Asli Buku Nikah untuk pasangan suami istri, atau Akta Lahir asli untuk anak di bawah umur yang ikut serta dalam rombongan.\"\n  }\n];\n"
    }
