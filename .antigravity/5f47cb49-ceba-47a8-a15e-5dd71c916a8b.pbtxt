  file_change {
    absolute_path_uri: "file:///src/components/Hero.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { MessageCircle, ArrowDown, ChevronRight, Sparkles, ShieldCheck } from \"lucide-react\";\nimport { companyData } from \"../data\";\n\nexport default function Hero() {\n  const scrollToPackages = () => {\n    const element = document.getElementById(\"packages-section\");\n    if (element) {\n      const offset = 100;\n      const bodyRect = document.body.getBoundingClientRect().top;\n      const elementRect = element.getBoundingClientRect().top;\n      const elementPosition = elementRect - bodyRect;\n      const offsetPosition = elementPosition - offset;\n\n      window.scrollTo({\n        top: offsetPosition,\n        behavior: \"smooth\"\n      });\n    }\n  };\n\n  const handleOpenConsultation = () => {\n    const message = encodeURIComponent(\n      \"Assalamualaikum Admin Al-Haramain Umrah, saya berkunjung ke website Anda dan ingin bertanya mengenai jadwal pendaftaran paket Umrah terdekat. Mohon bimbingannya.\"\n    );\n    window.open(`https://wa.me/${companyData.whatsappNumber}?text=${message}`, \"_blank\", \"noopener,noreferrer\");\n  };\n\n  return (\n    <section id=\"hero-section\" className=\"relative min-h-screen flex items-center justify-center pt-24 pb-12 overflow-hidden bg-emerald-950\">\n      {/* High-Resolution Generated Mecca Background Image with Vignette Overlay */}\n      <div className=\"absolute inset-0 z-0\">\n        <img\n          src=\"/src/assets/images/mecca_hero_banner_1779350890761.png\"\n          alt=\"Masjid al-Haram Mecca\"\n          className=\"w-full h-full object-cover object-center opacity-40 scale-105 animate-pulse-slow\"\n          referrerPolicy=\"no-referrer\"\n        />\n        {/* Double gradient layer to ensure extreme content readability and deep-editorial atmosphere */}\n        <div className=\"absolute inset-0 bg-gradient-to-r from-emerald-950/95 via-emerald-950/80 to-transparent\" />\n        <div className=\"absolute inset-0 bg-gradient-to-t from-emerald-950 via-transparent to-emerald-950/70\" />\n      </div>\n\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6 relative z-10 w-full pt-12\">\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-center\">\n          {/* Main Title Col (7 cols text blocks) */}\n          <div className=\"lg:col-span-8 text-left space-y-6\">\n            <div className=\"inline-flex items-center gap-2 bg-amber-400/10 text-amber-300 font-extrabold text-xs px-3.5 py-2 rounded-full border border-amber-400/25 uppercase tracking-wider animate-bounce-slow\">\n              <Sparkles className=\"w-4 h-4 text-amber-400\" />\n              <span>Sertifikasi PPIU Resmi Kemenag RI</span>\n            </div>\n\n            <h1 className=\"text-4xl sm:text-5xl md:text-6xl font-black text-white leading-[1.1] tracking-tight font-sans\">\n              Menyahut Panggilan Agung <br />\n              <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-amber-400 to-amber-200\">\n                Menuju Baitullah\n              </span>\n            </h1>\n\n            <p className=\"text-base sm:text-lg md:text-xl text-emerald-100/90 leading-relaxed max-w-2xl font-light\">\n              Rasakan kekhidmatan ibadah Umrah premium bersama <strong className=\"text-amber-400 font-bold\">{companyData.legalName}</strong>. Akomodasi hotel bintang 5 langsung menghadap Masjidil Haram, dipandu muthawwif bersertifikat.\n            </p>\n\n            {/* Big Action Buttons */}\n            <div className=\"flex flex-col sm:flex-row gap-4 pt-4\">\n              <button\n                onClick={scrollToPackages}\n                className=\"inline-flex items-center justify-center gap-2 bg-amber-500 hover:bg-amber-600 active:bg-amber-700 text-emerald-950 font-extrabold text-sm sm:text-base px-8 py-4 rounded-xl shadow-xl shadow-amber-500/10 hover:shadow-amber-500/20 transform hover:-translate-y-0.5 active:translate-y-px transition-all cursor-pointer\"\n              >\n                <span>Lihat Paket Pilihan</span>\n                <ChevronRight className=\"w-5 h-5 text-emerald-950\" />\n              </button>\n\n              <button\n                onClick={handleOpenConsultation}\n                className=\"inline-flex items-center justify-center gap-2 bg-emerald-700/80 hover:bg-emerald-700 hover:text-white active:bg-emerald-800 text-emerald-100 border border-emerald-500/40 rounded-xl font-bold text-sm sm:text-base px-8 py-4 transition-all cursor-pointer hover:shadow-lg hover:shadow-emerald-500/10\"\n              >\n                <MessageCircle className=\"w-5 h-5 text-emerald-300 animate-pulse\" />\n                <span>Konsultasi Syarat WA</span>\n              </button>\n            </div>\n\n            {/* Real Counter Statistics Strip */}\n            <div className=\"pt-10 grid grid-cols-3 gap-6 border-t border-emerald-800/40 max-w-xl\">\n              <div>\n                <p className=\"text-3xl md:text-4xl font-extrabold text-amber-400 font-mono\">5.000+</p>\n                <p className=\"text-xs text-emerald-200/80 font-medium mt-1\">Jamaah Berangkat</p>\n              </div>\n              <div>\n                <p className=\"text-3xl md:text-4xl font-extrabold text-amber-400 font-mono\">100%</p>\n                <p className=\"text-xs text-emerald-200/80 font-medium mt-1\">Safar Aman & Legal</p>\n              </div>\n              <div>\n                <p className=\"text-3xl md:text-4xl font-extrabold text-amber-400 font-mono\">\342\230\205\342\230\205\342\230\205\342\230\205\342\230\205</p>\n                <p className=\"text-xs text-emerald-200/80 font-medium mt-1\">Rating Kepuasan</p>\n              </div>\n            </div>\n          </div>\n\n          {/* Luxury Floating Trust Badge on Mobile/Desktop (5 cols visuals) */}\n          <div className=\"lg:col-span-4 flex justify-center items-center\">\n            <div className=\"bg-white/10 backdrop-blur-md rounded-3xl p-6 border border-white/10 max-w-[320px] shadow-2xl relative overflow-hidden group\">\n              <div className=\"absolute top-0 right-0 w-32 h-32 bg-amber-400/5 rounded-full blur-2xl pointer-events-none\" />\n\n              {/* Graphic element of Mosque Silhouette in line-art */}\n              <div className=\"text-center space-y-4\">\n                <span className=\"text-5xl inline-block drop-shadow-md\">\360\237\221\221</span>\n                <h4 className=\"font-extrabold text-white text-base font-sans\">Garansi \"5 Pasti\" Kemenag</h4>\n                <p className=\"text-xs text-emerald-200 leading-relaxed font-light\">\n                  Kami sepenuhnya patuh terhadap panduan keamanan perjalanan dari Kementerian Agama RI untuk menjamin ketenangan ibadah Anda sejak pendaftaran hingga kepulangan.\n                </p>\n                <div className=\"pt-4 border-t border-white/10 flex items-center justify-center gap-1.5 text-xs text-amber-400 font-bold\">\n                  <ShieldCheck className=\"w-4 h-4 text-emerald-400\" />\n                  <span>Izin PPIU Terbit & Valid</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      {/* Down Scroll Indicator arrow bouncing */}\n      <div className=\"absolute bottom-8 left-1/2 transform -translate-x-1/2 z-10 hidden sm:flex flex-col items-center gap-1.5 opacity-60 hover:opacity-100 transition-opacity\">\n        <span className=\"text-[10px] text-white font-bold tracking-widest uppercase\">Scroll Kebawah</span>\n        <button\n          onClick={scrollToPackages}\n          className=\"p-1.5 bg-emerald-900 border border-emerald-800 rounded-full text-amber-400 animate-bounce\"\n          aria-label=\"Scroll ke Paket\"\n        >\n          <ArrowDown className=\"w-4 h-4\" />\n        </button>\n      </div>\n    </section>\n  );\n}\n"
    }
