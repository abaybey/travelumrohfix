  file_change {
    absolute_path_uri: "file:///src/components/Legality.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { ShieldAlert, CheckCircle2, Award, HeartHandshake, Eye, Star } from \"lucide-react\";\nimport { companyData } from \"../data\";\n\nexport default function Legality() {\n  const fivePasti = [\n    {\n      title: \"Pasti Travel Berizin PPIU resmi\",\n      desc: \"PT Al-Haramain Mulia Wisata memegang nomor izin PPIU Kemenag RI No. 129 Tahun 2024. Resmi dan legal terdaftar di Siskopatuh Kemenag.\",\n      badge: \"Izin No 129\"\n    },\n    {\n      title: \"Pasti Jadwal & Maskapainya\",\n      desc: \"Seluruh tiket penerbangan PP Jakarta ke Arab Saudi kami pesan lunas sejak dini. Jadwal & maskapai diumumkan detail di awal brosur.\",\n      badge: \"Direct Flight\"\n    },\n    {\n      title: \"Pasti Terbang & Visanya\",\n      desc: \"Menjamin visa umrah Anda terbit resmi sebelum tanggal keberangkatan dengan verifikasi data biometrik komprehensif.\",\n      badge: \"Visa Terjamin\"\n    },\n    {\n      title: \"Pasti Hotel Akomodasinya\",\n      desc: \"Hotel yang kami tawarkan sesuai dengan kontrak kerja sama resmi. Jarak dekat dan hotel bintang 4 & bintang 5 garansi nyaman.\",\n      badge: \"Sesuai Kontrak\"\n    },\n    {\n      title: \"Pasti Layanan Fiqihnya\",\n      desc: \"Pendampingan ibadah dari tanah air hingga kepulangan dipandu oleh Muthawwif & Pembimbing bersertifikat lulusan Saudi.\",\n      badge: \"Sesuai Sunnah\"\n    }\n  ];\n\n  const features = [\n    {\n      icon: <Award className=\"w-6 h-6 text-amber-500\" />,\n      title: \"Berdiri Sejak 2018\",\n      desc: \"Berpengalaman memberangkatkan ribuan jamaah dengan track record keberangkatan 100% tepat waktu.\"\n    },\n    {\n      icon: <HeartHandshake className=\"w-6 h-6 text-amber-500\" />,\n      title: \"Bimbingan Terbaik\",\n      desc: \"Manasik umrah padat teori & praktek simulasi tawaf & sa\'i agar jamaah mandiri saat ibadah sesungguhnya.\"\n    },\n    {\n      icon: <Eye className=\"w-6 h-6 text-amber-500\" />,\n      title: \"Layanan Transparan\",\n      desc: \"Harga jujur (all-in) tanpa biaya tersembunyi yang ditagihkan di belakang hari menjelang keberangkatan.\"\n    },\n    {\n      icon: <Star className=\"w-6 h-6 text-amber-500\" />,\n      title: \"Keamanan Finansial\",\n      desc: \"Pembayaran terpusat via rekening resmi Bank Syariah Indonesia (BSI) atas nama PT Al-Haramain Mulia Wisata.\"\n    }\n  ];\n\n  return (\n    <section id=\"legality-section\" className=\"py-20 bg-amber-50/40 relative overflow-hidden\">\n      {/* Decorative Gold Elements */}\n      <div className=\"absolute top-0 right-0 w-80 h-80 bg-amber-300/10 rounded-full blur-3xl\" />\n      <div className=\"absolute bottom-0 left-0 w-80 h-80 bg-emerald-700/5 rounded-full blur-3xl\" />\n\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6 relative\">\n        {/* Section Heading */}\n        <div className=\"text-center max-w-3xl mx-auto mb-16\">\n          <div className=\"inline-flex items-center gap-1.5 bg-emerald-100 text-emerald-800 text-xs font-bold px-3 py-1.5 rounded-full mb-3 uppercase tracking-wider\">\n            \342\232\224\357\270\217 Izin Kementerian Agama RI PPIU\n          </div>\n          <h2 className=\"text-3xl sm:text-4xl font-extrabold text-gray-900 tracking-tight font-sans leading-tight\">\n            Ibadah Tenang, Nyaman & <span className=\"text-emerald-800\">Garansi 100% Legal</span>\n          </h2>\n          <p className=\"mt-4 text-base sm:text-lg text-gray-600 leading-relaxed\">\n            Menunaikan umrah adalah menyahut panggilan suci Allah SWT. Kami pastikan keberangkatan Anda terjamin aman secara hukum Negara dengan kepatuhan tinggi.\n          </p>\n        </div>\n\n        {/* Certificate Display Area */}\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-center mb-16\">\n          {/* Left Block - PPIU Accreditation Card */}\n          <div className=\"lg:col-span-5 bg-white rounded-2xl border border-amber-200/60 p-6 sm:p-8 shadow-xl shadow-amber-900/5 hover:border-amber-400 transition-all\">\n            <h3 className=\"text-xl font-bold text-gray-900 mb-3 font-sans\">Legalitas & Sertifikasi Resmi</h3>\n            <p className=\"text-gray-600 text-sm leading-relaxed mb-6\">\n              Izin PPIU merupakan lisensi resmi Penyelenggara Perjalanan Ibadah Umrah yang diterbitkan resmi oleh Kementerian Agama Republik Indonesia hanya untuk perusahaan dengan standar operasional yang ketat.\n            </p>\n\n            <div className=\"bg-emerald-950 text-white rounded-xl p-5 mb-6 relative overflow-hidden\">\n              <div className=\"absolute -right-6 -bottom-6 text-emerald-900/40 font-bold text-8xl\">RI</div>\n              <div className=\"flex items-center gap-3 mb-4\">\n                <span className=\"text-2xl\">\360\237\207\256\360\237\207\251</span>\n                <div>\n                  <h4 className=\"font-extrabold text-amber-400 text-sm tracking-wide\">KEMENTERIAN AGAMA RI</h4>\n                  <p className=\"text-[10px] text-emerald-300 uppercase\">Sertifikat Resmi PPIU</p>\n                </div>\n              </div>\n              <div className=\"border-t border-emerald-800 pt-3\">\n                <p className=\"text-xs text-emerald-200\">Terdaftar Atas Nama Perusahaan:</p>\n                <p className=\"font-bold text-base mt-1\">{companyData.legalName}</p>\n                <p className=\"text-amber-300 font-mono text-sm mt-1.5 font-bold\">{companyData.ppiuNumber}</p>\n              </div>\n            </div>\n\n            {/* List of Affiliations */}\n            <div>\n              <p className=\"text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3\">Asosiasi & Partner Maskapai Utama</p>\n              <div className=\"flex flex-wrap items-center gap-2\">\n                <span className=\"px-2.5 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold text-[10px] rounded border border-gray-200\">AMPHURI Member</span>\n                <span className=\"px-2.5 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold text-[10px] rounded border border-gray-200\">SISKOPATUH Aktif</span>\n                <span className=\"px-2.5 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold text-[10px] rounded border border-gray-200\">IATA Certified</span>\n                <span className=\"px-2.5 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold text-[10px] rounded border border-gray-200\">Kemenhub RI</span>\n              </div>\n            </div>\n          </div>\n\n          {/* Right Block - Official 5 Pasti Umrah */}\n          <div className=\"lg:col-span-7 space-y-4\">\n            <div className=\"bg-emerald-900 text-emerald-100 rounded-2xl p-6 shadow-lg mb-4\">\n              <div className=\"flex gap-4 items-start\">\n                <div className=\"bg-amber-400 text-emerald-950 p-2.5 rounded-xl font-bold shrink-0\">\n                  <ShieldAlert className=\"w-5 h-5\" />\n                </div>\n                <div>\n                  <h4 className=\"text-white font-extrabold text-base md:text-lg\">Gerakan Kemenag: 5 Pasti Umrah!</h4>\n                  <p className=\"text-xs sm:text-sm text-emerald-200 mt-1\">\n                    Kementerian Agama menghimbau masyarakat untuk mengecek 5 kepastian krusial sebelum menyerahkan dana pendaftaran ke biro mana pun. Di Al-Haramain, kami menjamin kelimanya:\n                  </p>\n                </div>\n              </div>\n            </div>\n\n            {/* 5 Pasti Accordion / Card Grid */}\n            <div className=\"grid grid-cols-1 md:grid-cols-5 gap-3\">\n              {fivePasti.map((item, idx) => (\n                <div key={idx} className=\"bg-white border border-gray-100 rounded-xl p-4 shadow-sm hover:shadow-md hover:border-emerald-200 transition-all flex flex-col justify-between\">\n                  <div>\n                    <span className=\"inline-block bg-emerald-100 text-emerald-800 text-[9px] font-bold px-2 py-0.5 rounded-full mb-2\">\n                      {item.badge}\n                    </span>\n                    <h5 className=\"font-bold text-gray-900 text-xs tracking-tight line-clamp-2 md:h-10\">\n                      {item.title}\n                    </h5>\n                    <p className=\"text-[11px] text-gray-500 mt-1 md:mt-2 leading-relaxed line-clamp-4\">\n                      {item.desc}\n                    </p>\n                  </div>\n                  <div className=\"pt-2 mt-2 border-t border-gray-50 flex items-center justify-between text-emerald-600\">\n                    <span className=\"text-[10px] font-mono font-bold text-emerald-700\">Pasti {idx + 1}</span>\n                    <CheckCircle2 className=\"w-4 h-4 text-emerald-600 shrink-0\" />\n                  </div>\n                </div>\n              ))}\n            </div>\n          </div>\n        </div>\n\n        {/* Dynamic Trust Features Cards */}\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 pt-8 border-t border-gray-200/60\">\n          {features.map((feat, index) => (\n            <div key={index} className=\"flex gap-4 items-start p-4 bg-white/60 hover:bg-white rounded-xl border border-transparent hover:border-amber-200 transition-all duration-300\">\n              <div className=\"p-3 bg-amber-100 text-amber-800 rounded-xl\">\n                {feat.icon}\n              </div>\n              <div>\n                <h4 className=\"font-bold text-gray-900 text-sm\">{feat.title}</h4>\n                <p className=\"text-xs text-gray-500 mt-1 leading-relaxed\">\n                  {feat.desc}\n                </p>\n              </div>\n            </div>\n          ))}\n        </div>\n      </div>\n    </section>\n  );\n}\n"
